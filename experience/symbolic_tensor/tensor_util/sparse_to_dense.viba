sparse_to_dense :=
    Symbolic[torch.Tensor]
    <- $input Symbolic[torch.Tensor]
    <- $indexes list[torch.Tensor[Index]]
    <- $shape list[int]
    # inline
    <- Import[experience/symbolic_tensor/tensor_util/make_none_tensor.viba]
    <- Import[experience/symbolic_tensor/tensor_util/slice_view.viba]
    <- Import[experience/symbolic_tensor/tensor_util/assign_tensor.viba]